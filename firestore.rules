rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isSelf(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function isSuperAdmin() {
      return isSignedIn() && request.auth.token.role == 'super_admin';
    }

    // ── Helpers ────────────────────────────────────────────────────────────
    // Centralized cross-doc lookups so the redemption rule stays readable.

    function customerData(uid) {
      return get(/databases/$(database)/documents/customers/$(uid)).data;
    }

    function customerTotalPoints(uid) {
      return customerData(uid).get('total_points', 0);
    }

    function catalogueItem(id) {
      return get(/databases/$(database)/documents/catalogue/$(id)).data;
    }

    // Admins (optional profile docs)
    match /users/{uid} {
      allow read: if isSelf(uid) || isSuperAdmin();
      allow write: if isSuperAdmin();
    }

    // Customers — profile doc keyed by Firebase Auth UID.
    match /customers/{uid} {
      allow read: if isSelf(uid) || isSuperAdmin();

      // First-time self-registration. Whitelist the exact fields the app writes,
      // pin total_points to 0, require strings (not numbers/objects) for text fields.
      allow create: if isSelf(uid)
        && request.resource.data.keys().hasOnly([
             'first_name', 'last_name', 'email', 'phone',
             'date_of_birth', 'total_points', 'created_at'
           ])
        && request.resource.data.keys().hasAll([
             'first_name', 'last_name', 'email', 'phone', 'total_points'
           ])
        && request.resource.data.first_name is string
        && request.resource.data.last_name is string
        && request.resource.data.email is string
        && request.resource.data.phone is string
        && request.resource.data.total_points == 0;

      // Admins can update any field. Customers can only DECREMENT their own
      // `total_points` (no other field touched, value strictly less than current,
      // must remain a non-negative int). This pairs with the redemption.create
      // balance check below: the redemption SDK transaction decrements
      // total_points and creates the redemption atomically. Because customers
      // can never self-increment, they cannot mint points.
      allow update: if isSuperAdmin()
        || (
          isSelf(uid)
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['total_points'])
          && request.resource.data.total_points is int
          && request.resource.data.total_points >= 0
          && request.resource.data.total_points < resource.data.get('total_points', 0)
        );

      allow delete: if isSuperAdmin();
    }

    // Catalogue — any signed-in user reads; super admins write.
    match /catalogue/{itemId} {
      allow read: if isSignedIn();
      allow write: if isSuperAdmin();
    }

    // Claims (in-store receipt submissions awaiting approval).
    // Customer can create a PENDING claim for themselves with capped/computed values.
    // Only admins can approve or modify after creation.
    match /claims/{claimId} {
      allow read: if isSuperAdmin()
                  || (isSignedIn() && resource.data.customer_id == request.auth.uid);

      allow create: if isSignedIn()
        && request.resource.data.keys().hasOnly([
             'customer_id', 'customer_name', 'customer_email', 'customer_phone',
             'claimed_amount', 'points_to_award', 'status', 'submitted_at'
           ])
        && request.resource.data.customer_id == request.auth.uid
        && request.resource.data.status == 'PENDING'
        && request.resource.data.claimed_amount is number
        && request.resource.data.claimed_amount >= 10
        && request.resource.data.claimed_amount <= 100000
        && request.resource.data.points_to_award is int
        && request.resource.data.points_to_award >= 0
        // The decisive check: server pins points to floor(amount / 10).
        // Customer cannot inflate points_to_award via DevTools or Postman.
        && request.resource.data.points_to_award == int(request.resource.data.claimed_amount) / 10
        && request.resource.data.submitted_at == request.time;

      allow update, delete: if isSuperAdmin();
    }

    // Points batches — only admins can create/modify (admin SDK or admin browser session).
    // Customers read only their own.
    match /points_batches/{batchId} {
      allow read: if isSuperAdmin()
                  || (isSignedIn() && resource.data.customer_id == request.auth.uid);
      allow write: if isSuperAdmin();
    }

    // Redemptions — customer creates PENDING for themselves; admin confirms/fulfills.
    //
    // C1 fix: balance is enforced server-side here. The client SDK transaction
    //   1) reads customers/{uid}.total_points
    //   2) writes the decremented total_points
    //   3) creates this redemption with points_used == catalogue.points_cost
    // Both writes commit atomically. Concurrent transactions retry on contention,
    // so two parallel redemptions cannot both pass a 100-point check against the
    // same 100-point balance.
    //
    // Defense-in-depth: even without the decrement (i.e. a tampered client that
    // skips the customer update), the rule below denies the redemption when
    // points_used > current total_points.
    match /redemptions/{redemptionId} {
      allow read: if isSuperAdmin()
                  || (isSignedIn() && resource.data.customer_id == request.auth.uid);

      allow create: if isSignedIn()
        // Field whitelist — block any admin-only or surprise fields at create time.
        && request.resource.data.keys().hasOnly([
             'customer_id', 'customer_name', 'customer_phone',
             'catalogue_item_id', 'catalogue_item_name', 'catalogue_item_photo',
             'points_used', 'method', 'status', 'otp_hash',
             'delivery_recipient_name', 'delivery_phone', 'delivery_street',
             'delivery_city', 'delivery_notes', 'delivery_address',
             'created_at'
           ])
        && request.resource.data.keys().hasAll([
             'customer_id', 'customer_name', 'customer_phone',
             'catalogue_item_id', 'catalogue_item_name', 'catalogue_item_photo',
             'points_used', 'method', 'status', 'created_at'
           ])
        // Identity + status + server time.
        && request.resource.data.customer_id == request.auth.uid
        && request.resource.data.status == 'PENDING'
        && request.resource.data.created_at == request.time
        // Denormalized customer name + phone anchored to customers/{uid}.
        // Stops impersonation ("Admin Owner", someone else's phone) on the cashier screen.
        && request.resource.data.customer_name ==
             (customerData(request.auth.uid).get('first_name', '') + ' ' +
              customerData(request.auth.uid).get('last_name', '')).trim()
        && request.resource.data.customer_phone == customerData(request.auth.uid).get('phone', '')
        // Balance gate (C1).
        && request.resource.data.points_used is int
        && request.resource.data.points_used > 0
        && request.resource.data.points_used <= customerTotalPoints(request.auth.uid)
        // Catalogue item must exist (get() denies if missing), be active, and
        // have a positive integer points_cost matching points_used.
        && request.resource.data.catalogue_item_id is string
        && catalogueItem(request.resource.data.catalogue_item_id).get('is_active', false) == true
        && catalogueItem(request.resource.data.catalogue_item_id).points_cost is int
        && catalogueItem(request.resource.data.catalogue_item_id).points_cost > 0
        && request.resource.data.points_used == catalogueItem(request.resource.data.catalogue_item_id).points_cost
        // Display fields anchored to the catalogue doc — no attacker-supplied
        // name shown to the admin, no attacker-supplied photo URL.
        && request.resource.data.catalogue_item_name == catalogueItem(request.resource.data.catalogue_item_id).name
        && request.resource.data.catalogue_item_photo == catalogueItem(request.resource.data.catalogue_item_id).get('photo_url', null)
        // Method-specific validation. IN_STORE requires a 6-digit OTP and forbids
        // delivery fields. ONLINE requires the delivery fields with sane caps and
        // forbids an OTP. Either branch must match exactly.
        && request.resource.data.method in ['IN_STORE', 'ONLINE']
        && (
          (
            request.resource.data.method == 'IN_STORE'
            && 'otp_hash' in request.resource.data
            && request.resource.data.otp_hash is string
            && request.resource.data.otp_hash.matches('^[a-f0-9]{64}$')
            && !('delivery_recipient_name' in request.resource.data)
            && !('delivery_phone' in request.resource.data)
            && !('delivery_street' in request.resource.data)
            && !('delivery_city' in request.resource.data)
            && !('delivery_notes' in request.resource.data)
            && !('delivery_address' in request.resource.data)
          ) || (
            request.resource.data.method == 'ONLINE'
            && !('otp_hash' in request.resource.data)
            && request.resource.data.delivery_recipient_name is string
            && request.resource.data.delivery_recipient_name.size() >= 1
            && request.resource.data.delivery_recipient_name.size() <= 200
            && request.resource.data.delivery_phone is string
            && request.resource.data.delivery_phone.size() >= 1
            && request.resource.data.delivery_phone.size() <= 50
            && request.resource.data.delivery_street is string
            && request.resource.data.delivery_street.size() >= 1
            && request.resource.data.delivery_street.size() <= 300
            && request.resource.data.delivery_city is string
            && request.resource.data.delivery_city.size() >= 1
            && request.resource.data.delivery_city.size() <= 100
            && (
              !('delivery_notes' in request.resource.data)
              || request.resource.data.delivery_notes == null
              || (request.resource.data.delivery_notes is string && request.resource.data.delivery_notes.size() <= 1000)
            )
            && (
              !('delivery_address' in request.resource.data)
              || (request.resource.data.delivery_address is string && request.resource.data.delivery_address.size() <= 2000)
            )
          )
        );

      allow update, delete: if isSuperAdmin();
    }

    // Fraud alerts — super admin only.
    match /fraud_alerts/{alertId} {
      allow read, write: if isSuperAdmin();
    }
  }
}
